# === 필수 ===
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1234567890
TWILIO_PUBLIC_BASE_URL=https://your-subdomain.ngrok.io
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === 발신자 정보 ===
# 예: "오한 박사님의 인공지능 비서입니다"
MASTER_NAME=오한
MASTER_TITLE=박사
CALLER_NAME=인공지능
CALLER_TITLE=비서

# === 선택 ===
OPENAI_CALL_MODEL=gpt-5-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_REALTIME_MODEL=gpt-realtime-mini
OPENAI_REALTIME_VOICE=coral
MAX_CALL_TURNS=12

# === ElevenLabs TTS (선택, 고품질 음성) ===
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_STABILITY=0.42
ELEVENLABS_SIMILARITY=0.78
ELEVENLABS_STYLE=0.18

# === ngrok (선택) ===
NGROK_AUTH_TOKEN=
